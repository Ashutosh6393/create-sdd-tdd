{
  "name": "create-sdd-tdd",
  "version": "0.1.0",
  "description": "Scaffold a spec-driven-development + TDD project template via npx create-sdd-tdd <dir>.",
  "keywords": [
    "scaffold",
    "cli",
    "create",
    "template",
    "spec-driven-development",
    "sdd",
    "tdd",
    "ai",
    "claude"
  ],
  "author": "vashutosh625@gmail.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ashutosh6393/create-sdd-tdd.git"
  },
  "homepage": "https://github.com/Ashutosh6393/create-sdd-tdd#readme",
  "bugs": "https://github.com/Ashutosh6393/create-sdd-tdd/issues",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "template"
  ],
  "bin": {
    "create-sdd-tdd": "dist/cli.js"
  },
  "scripts": {
